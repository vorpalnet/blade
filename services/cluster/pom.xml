	<artifactId>vorpal-blade-services-cluster</artifactId>
	<packaging>ear</packaging>
	<name>BLADE Cluster EAR</name>
	<description>Single deployable that bundles every BLADE engine-tier service WAR,
		so the whole services tier deploys to the cluster in one step — the mirror
		of admin/ear's blade-admin.ear. Each WAR is self-contained exactly as it
		deploys on its own (framework jar inside + `vorpal-blade` shared-library
		reference in its own weblogic.xml); this EAR is purely a packaging
		convenience and bundles no libraries itself.

		Each service is contributed by its own ear-&lt;name&gt; profile, activated by
		!skip.&lt;name&gt; — the same flags build.sh derives from the active
		build-profiles/*.conf. So a trimmed profile (e.g. minimal) that builds only
		a subset of services produces an EAR containing exactly that subset, with no
		dangling references to WARs that aren't in the reactor.

		The test apps (test-uac, test-uas, test-b2bua) are bundled the same way
		when the active profile includes them — promoted to production 2026-06-05
		as live-diagnostics tools. services/context likewise (promoted
		2026-06-05): every services-tier WAR now rides this EAR.</description>

	<dependencies>
		<!-- Service WAR modules are contributed via the ear-* profiles below.
		     No JARs in this EAR — framework is in each WAR, 3rd-party libs come
		     from the vorpal-blade shared library at runtime. -->
	</dependencies>

	<build>
		<finalName>blade-cluster</finalName>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-ear-plugin</artifactId>
				<configuration>
					<!-- Jakarta EE 8 (OCCAS / WebLogic 14.1.1), matching admin/ear. -->
					<version>8</version>
					<generateApplicationXml>true</generateApplicationXml>
					<displayName>BLADE Cluster</displayName>
					<!-- Context roots are stated explicitly (per webModule below) so
					     they exactly match each WAR's weblogic.xml; application.xml
					     wins over weblogic.xml in an EAR. Never change them — they
					     are fixed deployment identifiers. -->
				</configuration>
			</plugin>
		</plugins>
	</build>

	<profiles>
		<!-- One profile per service WAR. Active by default; build.sh excludes a
		     service with -Dskip.<name> when it's absent from the active
		     build-profiles/*.conf. Each profile contributes BOTH the war
		     dependency AND its webModule (combine.children="append"), so the two
		     never drift and a skipped service drops cleanly out of the EAR. -->
		<profile>
			<id>ear-acl</id>
			<activation><property><name>!skip.acl</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-acl</artifactId>
					<version>${project.version}</version>
					<type>war</type>
					<exclusions><exclusion><groupId>*</groupId><artifactId>*</artifactId></exclusion></exclusions>
				</dependency>
			</dependencies>
			<build><plugins><plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-ear-plugin</artifactId>
				<configuration>
					<modules combine.children="append">
						<webModule>
							<groupId>org.vorpal.blade</groupId>
							<artifactId>vorpal-blade-services-acl</artifactId>
							<contextRoot>acl</contextRoot>
							<bundleFileName>acl.war</bundleFileName>
						</webModule>
					</modules>
				</configuration>
			</plugin></plugins></build>
		</profile>
