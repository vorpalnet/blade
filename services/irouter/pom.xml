<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.vorpal.blade</groupId>
		<artifactId>vorpal-blade</artifactId>
		<version>${revision}</version>
		<relativePath>../../pom.xml</relativePath>
	</parent>

	<artifactId>vorpal-blade-services-irouter</artifactId>
	<packaging>war</packaging>
	<name>BLADE Intelligent Router Service</name>

	<dependencies>
		<dependency>
			<groupId>org.vorpal.blade</groupId>
			<artifactId>vorpal-blade-library-framework</artifactId>
		</dependency>
	</dependencies>

	<build>
		<finalName>irouter</finalName>
		<plugins>
			<!-- Publish a -classes.jar alongside the WAR so commercial
			     extensions (e.g. connect/securelogix) can depend on
			     IRouterServlet/IRouterInvite for Java inheritance.

			     We DON'T use war-plugin's <attachClasses>true</attachClasses>
			     because that would scoop up IRouterApp.class — the
			     @SipApplication-annotated leaf that activates iRouter as
			     the standalone WAR's SIP servlet. Bundling that leaf into
			     a downstream WAR (SecureLogix) makes WLS see TWO
			     @SipApplication classes in one app and refuse to deploy
			     ("Redundant annotation @SipApplication in one module").

			     Instead, we drive maven-jar-plugin directly with an
			     explicit `exclude` for IRouterApp.class. The resulting
			     -classes.jar carries only the inheritable base classes. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<executions>
					<execution>
						<id>inheritable-classes-jar</id>
						<phase>package</phase>
						<goals><goal>jar</goal></goals>
						<configuration>
							<classifier>classes</classifier>
							<excludes>
								<!-- Annotated leaf classes belong only in the
								     standalone iRouter WAR, never in the
								     inheritable JAR (see class Javadoc on
								     IRouterServlet). Add new leaves here when
								     they're added to this module. -->
								<exclude>**/IRouterApp.class</exclude>
							</excludes>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

</project>
