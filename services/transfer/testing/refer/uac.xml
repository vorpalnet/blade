<scenario name="Basic Sipstone UAC">
  <!-- In client mode (sipp placing calls), the Call-ID MUST be         -->
  <!-- generated by sipp. To do so, use [call_id] keyword.                -->
	<send retrans="500">
    <![CDATA[

      REFER sip:wlssuser@172.16.32.129:5060;transport=tcp;wlsscid=5fbb8cb142088f50;sipappsessionid=app-1fyd3a611v7sq;wlssfcid=sip-12f6jb4sjjrth SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: <sip:bob@vorpal.net>;tag=1aa0bff0
      To: "Alice" <sip:alice@vorpal.net>;tag=bf00dc31
      Content-Length: 0
      Refer-To: <sip:carol@vorpal.net>
      Max-Breadth: 60
      Referred-By: <sip:bob@vorpal.net>
      CSeq: 3 REFER
      Contact: sip:sipp@[local_ip]:[local_port]
      Call-ID: [call_id]
      Max-Forwards: 70

    ]]>
	</send>

	<recv response="202" rtd="true">
	</recv>
	
	<recv request="NOTIFY">
    </recv>
	

	<send retrans="500">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

    ]]>
  </send>
	
	

	<recv response="200" crlf="true">
	</recv>
  <!-- definition of the response time repartition table (unit is ms)   -->
	<ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200" />

  <!-- definition of the call length repartition table (unit is ms)     -->
	<CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000" />

</scenario>

