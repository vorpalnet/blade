					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-proxy-block</id>
			<activation><property><name>!skip.proxy-block</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-proxy-block</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-proxy-registrar</id>
			<activation><property><name>!skip.proxy-registrar</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-proxy-registrar</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-proxy-router</id>
			<activation><property><name>!skip.proxy-router</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-proxy-router</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-queue</id>
			<activation><property><name>!skip.queue</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-queue</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-tpcc</id>
			<activation><property><name>!skip.tpcc</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-tpcc</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-transfer</id>
			<activation><property><name>!skip.transfer</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-transfer</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-test-b2bua</id>
			<activation><property><name>!skip.test-b2bua</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>test-b2bua</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-test-uac</id>
			<activation><property><name>!skip.test-uac</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>test-uac</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>
		<profile>
			<id>ear-test-uas</id>
			<activation><property><name>!skip.test-uas</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>test-uas</artifactId>
					<version>${project.version}</version>
					<type>war</type>
				</dependency>
			</dependencies>
		</profile>

		<!-- WebLogic deployment profiles.
		     Override connection defaults with -Dwls.adminurl=... -Dwls.user=... -Dwls.password=... -Dwls.targets=...
		     Usage:
		       ./build.sh -\- -Pdeploy -Dwls.password=secret
		       ./build.sh -\- -Pundeploy -Dwls.password=secret
		       ./build.sh -\- -Pstop -Dwls.password=secret
		       ./build.sh -\- -Pstart -Dwls.password=secret
		-->
		<profile>
			<id>deploy</id>
			<properties>
				<wls.adminurl>t3://localhost:7001</wls.adminurl>
				<wls.user>weblogic</wls.user>
				<wls.password></wls.password>
				<wls.targets>AdminServer</wls.targets>
			</properties>
			<build>
				<plugins>
					<plugin>
						<groupId>com.oracle.weblogic</groupId>
						<artifactId>weblogic-maven-plugin</artifactId>
						<version>14.1.1</version>
						<executions>
							<execution>
								<id>deploy-ear</id>
								<phase>pre-integration-test</phase>
								<goals>
									<goal>deploy</goal>
								</goals>
								<configuration>
									<adminurl>${wls.adminurl}</adminurl>
									<user>${wls.user}</user>
									<password>${wls.password}</password>
									<targets>${wls.targets}</targets>
									<source>${project.build.directory}/${project.build.finalName}.ear</source>
									<name>vorpal-blade-services</name>
									<upload>true</upload>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>
		<profile>
			<id>undeploy</id>
			<properties>
				<wls.adminurl>t3://localhost:7001</wls.adminurl>
				<wls.user>weblogic</wls.user>
				<wls.password></wls.password>
				<wls.targets>AdminServer</wls.targets>
			</properties>
			<build>
				<plugins>
					<plugin>
						<groupId>com.oracle.weblogic</groupId>
						<artifactId>weblogic-maven-plugin</artifactId>
						<version>14.1.1</version>
						<executions>
							<execution>
								<id>undeploy-ear</id>
								<phase>pre-integration-test</phase>
								<goals>
									<goal>undeploy</goal>
								</goals>
								<configuration>
									<adminurl>${wls.adminurl}</adminurl>
									<user>${wls.user}</user>
									<password>${wls.password}</password>
									<targets>${wls.targets}</targets>
									<name>vorpal-blade-services</name>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>
		<profile>
			<id>stop</id>
			<properties>
				<wls.adminurl>t3://localhost:7001</wls.adminurl>
				<wls.user>weblogic</wls.user>
				<wls.password></wls.password>
				<wls.targets>AdminServer</wls.targets>
			</properties>
			<build>
				<plugins>
					<plugin>
						<groupId>com.oracle.weblogic</groupId>
						<artifactId>weblogic-maven-plugin</artifactId>
						<version>14.1.1</version>
						<executions>
							<execution>
								<id>stop-ear</id>
								<phase>pre-integration-test</phase>
								<goals>
									<goal>stop-app</goal>
								</goals>
								<configuration>
									<adminurl>${wls.adminurl}</adminurl>
									<user>${wls.user}</user>
									<password>${wls.password}</password>
									<targets>${wls.targets}</targets>
									<name>vorpal-blade-services</name>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>
		<profile>
			<id>start</id>
			<properties>
				<wls.adminurl>t3://localhost:7001</wls.adminurl>
				<wls.user>weblogic</wls.user>
				<wls.password></wls.password>
				<wls.targets>AdminServer</wls.targets>
			</properties>
			<build>
