		<!-- WebLogic deployment profiles.
		     Override connection defaults with -Dwls.adminurl=... -Dwls.user=... -Dwls.password=... -Dwls.targets=...
		     Usage:
		       ./build.sh -\- -Pdeploy -Dwls.password=secret
		       ./build.sh -\- -Pundeploy -Dwls.password=secret
		       ./build.sh -\- -Pstop -Dwls.password=secret
		       ./build.sh -\- -Pstart -Dwls.password=secret
		-->
		<profile>
			<id>deploy</id>
			<properties>
				<wls.adminurl>t3://localhost:7001</wls.adminurl>
				<wls.user>weblogic</wls.user>
				<wls.password></wls.password>
				<wls.targets>AdminServer</wls.targets>
			</properties>
			<build>
				<plugins>
					<plugin>
						<groupId>com.oracle.weblogic</groupId>
						<artifactId>weblogic-maven-plugin</artifactId>
						<version>14.1.1</version>
