		</profile>
		<profile>
			<id>ear-proxy-balancer</id>
			<activation><property><name>!skip.proxy-balancer</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-services-proxy-balancer</artifactId>
