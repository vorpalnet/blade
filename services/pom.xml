			<!-- Strip multi-release classes above Java 11 from JARs inside the EAR.
			     WebLogic's classloader doesn't handle multi-release JARs correctly
			     and chokes on classes compiled for newer Java versions.
			     Only needed for Java 11; later JDKs handle multi-release JARs correctly.
			     Preserves META-INF/versions/9/ and META-INF/versions/11/. -->
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.5.0</version>
				<executions>
					<execution>
						<id>strip-multirelease</id>
						<phase>package</phase>
						<goals><goal>exec</goal></goals>
						<configuration>
							<executable>bash</executable>
							<arguments>
								<argument>-c</argument>
								<argument>
									JAVA_VER="${java.version}";
									if [ "$JAVA_VER" = "11" ]; then
										for jar in ${project.build.directory}/${project.build.finalName}/lib/*.jar; do
											for ver in $(jar tf "$jar" 2>/dev/null | grep 'META-INF/versions/' | sed 's|META-INF/versions/||' | cut -d/ -f1 | sort -un); do
												if [ "$ver" -gt 11 ]; then
													zip -qd "$jar" "META-INF/versions/$ver/*" 2>/dev/null || true
												fi
											done
										done;
										cd ${project.build.directory}/${project.build.finalName} &amp;&amp;
										jar uf ../${project.build.finalName}.ear lib/ &amp;&amp;
										echo "Stripped multi-release classes above Java 11 from EAR lib/ JARs";
										DISTDIR="${project.basedir}/../dist/${revision}-${build.number}";
										if [ -d "$DISTDIR" ]; then
											cp -f ${project.build.directory}/${project.build.finalName}.ear "$DISTDIR/"
										fi
									else
										echo "Skipping multi-release stripping (java.version=$JAVA_VER, only needed for 11)"
									fi
								</argument>
							</arguments>
						</configuration>
					</execution>
					<execution>
						<id>copy-dist</id>
						<phase>verify</phase>
						<goals><goal>exec</goal></goals>
						<configuration>
							<executable>bash</executable>
							<arguments>
								<argument>-c</argument>
								<argument>
									ROOTDIR="${project.basedir}/..";
									DISTDIR="$ROOTDIR/dist/${revision}-${build.number}";
									mkdir -p "$DISTDIR" &amp;&amp;
									cp -f ${project.build.directory}/${project.build.finalName}.ear "$DISTDIR/";
									cp -f "$ROOTDIR/libs/framework/target/vorpal-blade-library-framework.jar" "$DISTDIR/" 2>/dev/null;
									cp -f "$ROOTDIR/libs/shared/target/vorpal-blade-library-shared.war" "$DISTDIR/" 2>/dev/null;
									cp -f "$ROOTDIR/libs/fsmar/target/vorpal-blade-library-fsmar.jar" "$DISTDIR/" 2>/dev/null;
									cp -f "$ROOTDIR/admin/console/target/vorpal-blade-admin-console.war" "$DISTDIR/" 2>/dev/null;
									cp -f "$ROOTDIR/admin/configurator/target/vorpal-blade-admin-configurator.war" "$DISTDIR/" 2>/dev/null;
									echo "Dist artifacts copied to dist/${revision}-${build.number}/"
								</argument>
							</arguments>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
