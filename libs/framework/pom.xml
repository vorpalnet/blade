<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.vorpal.blade</groupId>
		<artifactId>vorpal-blade</artifactId>
		<version>${revision}</version>
		<relativePath>../../pom.xml</relativePath>
	</parent>

	<artifactId>vorpal-blade-library-framework</artifactId>
	<packaging>jar</packaging>
	<name>BLADE Framework Library</name>

	<dependencies>
		<!-- 3rd-party deps at compile scope so they flow transitively to
		     any module that depends on the framework. At runtime these
		     come from the shared library WAR; the parent pom's WAR plugin
		     packagingExcludes strips them from WEB-INF/lib. -->
		<dependency>
			<groupId>com.fasterxml.jackson.dataformat</groupId>
			<artifactId>jackson-dataformat-xml</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-databind</artifactId>
		</dependency>
		<dependency>
			<groupId>org.slf4j</groupId>
			<artifactId>slf4j-api</artifactId>
		</dependency>
		<!-- victools jsonschema-generator: replaces the legacy kjetland
		     mbknor-jackson-jsonschema (Scala, Draft 4 only). Pure Java,
		     active maintenance, modern JSON Schema drafts, customizable
		     subtype resolvers. Configurator consumes its output. -->
		<dependency>
			<groupId>com.github.victools</groupId>
			<artifactId>jsonschema-generator</artifactId>
		</dependency>
		<dependency>
			<groupId>com.github.victools</groupId>
			<artifactId>jsonschema-module-jackson</artifactId>
		</dependency>
		<!-- Kjetland's annotations (e.g. @JsonSchemaTitle) are still used
		     by many service config classes. The generator code path is
		     gone, but the annotations need to be on the compile classpath
		     until services migrate to Jackson-native or victools-native
		     metadata. They're no-ops at runtime under victools. -->
		<dependency>
			<groupId>com.kjetland</groupId>
			<artifactId>mbknor-jackson-jsonschema_2.13</artifactId>
		</dependency>
		<dependency>
			<groupId>io.swagger.core.v3</groupId>
			<artifactId>swagger-jaxrs2</artifactId>
		</dependency>
		<dependency>
			<groupId>com.jayway.jsonpath</groupId>
			<artifactId>json-path</artifactId>
		</dependency>
		<dependency>
			<groupId>com.github.seancfoley</groupId>
			<artifactId>ipaddress</artifactId>
		</dependency>
		<dependency>
			<groupId>org.apache.commons</groupId>
			<artifactId>commons-collections4</artifactId>
		</dependency>
		<dependency>
			<groupId>org.apache.commons</groupId>
			<artifactId>commons-email</artifactId>
		</dependency>
		<dependency>
			<groupId>com.nimbusds</groupId>
			<artifactId>oauth2-oidc-sdk</artifactId>
		</dependency>
	</dependencies>

	<build>
		<finalName>vorpal-blade-library-framework</finalName>
		<!-- Opt out of the parent POM's .java-bundling resource. The framework
		     ships sources as a separate -sources.jar (see maven-source-plugin
		     below) so downstream WARs that bundle the framework don't carry a
		     duplicate copy of every .java file inside their WEB-INF/classes. -->
		<resources>
			<resource>
				<directory>src/main/resources</directory>
			</resource>
		</resources>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-install-plugin</artifactId>
				<configuration>
					<skip>false</skip>
				</configuration>
			</plugin>
			<!-- Produce vorpal-blade-library-framework-<ver>-sources.jar so
			     Eclipse can attach source for the framework JAR pulled from
			     ~/.m2 (otherwise IDE shows "no source attachment"). -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-source-plugin</artifactId>
				<version>${maven-source-plugin.version}</version>
				<executions>
					<execution>
						<id>attach-sources</id>
						<goals>
							<goal>jar-no-fork</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

</project>
