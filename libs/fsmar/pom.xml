<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.vorpal.blade</groupId>
		<artifactId>vorpal-blade</artifactId>
		<version>${revision}</version>
		<relativePath>../../pom.xml</relativePath>
	</parent>

	<artifactId>vorpal-blade-fsmar</artifactId>
	<packaging>jar</packaging>
	<name>Vorpal:BLADE FSMAR Library</name>

	<dependencies>
		<dependency>
			<groupId>org.vorpal.blade</groupId>
			<artifactId>vorpal-blade-framework</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.dataformat</groupId>
			<artifactId>jackson-dataformat-xml</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-databind</artifactId>
		</dependency>
		<dependency>
			<groupId>org.slf4j</groupId>
			<artifactId>slf4j-api</artifactId>
		</dependency>
		<dependency>
			<groupId>com.github.seancfoley</groupId>
			<artifactId>ipaddress</artifactId>
		</dependency>
	</dependencies>

	<build>
		<finalName>vorpal-blade-fsmar</finalName>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-shade-plugin</artifactId>
				<version>3.6.0</version>
				<executions>
					<execution>
						<phase>package</phase>
						<goals><goal>shade</goal></goals>
						<configuration>
							<!-- Exclude provided-scope deps (OCCAS/WebLogic JARs) -->
							<artifactSet>
								<excludes>
									<exclude>javax:javaee-api</exclude>
									<exclude>com.oracle.weblogic:*</exclude>
									<exclude>com.oracle.occas:*</exclude>
								</excludes>
							</artifactSet>
							<!-- Strip multi-release classes above Java 11 that crash
							     WebLogic's classloader. Preserves versions/9/ and versions/11/. -->
							<filters>
								<filter>
									<artifact>*:*</artifact>
									<excludes>
										<exclude>META-INF/versions/12/**</exclude>
										<exclude>META-INF/versions/13/**</exclude>
										<exclude>META-INF/versions/14/**</exclude>
										<exclude>META-INF/versions/15/**</exclude>
										<exclude>META-INF/versions/16/**</exclude>
										<exclude>META-INF/versions/17/**</exclude>
										<exclude>META-INF/versions/18/**</exclude>
										<exclude>META-INF/versions/19/**</exclude>
										<exclude>META-INF/versions/20/**</exclude>
										<exclude>META-INF/versions/21/**</exclude>
										<exclude>META-INF/versions/22/**</exclude>
										<exclude>META-INF/versions/23/**</exclude>
										<exclude>META-INF/versions/24/**</exclude>
										<exclude>META-INF/versions/25/**</exclude>
									</excludes>
								</filter>
							</filters>
							<transformers>
								<!-- Merge META-INF/services files from all JARs -->
								<transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
							</transformers>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

</project>
