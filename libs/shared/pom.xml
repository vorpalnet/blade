<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.vorpal.blade</groupId>
		<artifactId>vorpal-blade</artifactId>
		<version>${revision}</version>
		<relativePath>../../pom.xml</relativePath>
	</parent>

	<artifactId>vorpal-blade-library-shared</artifactId>
	<packaging>war</packaging>
	<name>BLADE Shared Libraries</name>

	<dependencies>
		<!-- 3rd-party libraries only (no framework JAR — it goes in each service WAR) -->
		<dependency>
			<groupId>com.fasterxml.jackson.dataformat</groupId>
			<artifactId>jackson-dataformat-xml</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-databind</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-core</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-annotations</artifactId>
		</dependency>
		<dependency>
			<groupId>com.github.joschi.jackson</groupId>
			<artifactId>jackson-datatype-threetenbp</artifactId>
		</dependency>
		<dependency>
			<groupId>org.slf4j</groupId>
			<artifactId>slf4j-api</artifactId>
		</dependency>
		<dependency>
			<groupId>org.slf4j</groupId>
			<artifactId>slf4j-simple</artifactId>
		</dependency>
		<dependency>
			<groupId>com.jayway.jsonpath</groupId>
			<artifactId>json-path</artifactId>
		</dependency>
		<dependency>
			<groupId>com.kjetland</groupId>
			<artifactId>mbknor-jackson-jsonschema_2.13</artifactId>
		</dependency>
		<dependency>
			<groupId>io.swagger.core.v3</groupId>
			<artifactId>swagger-jaxrs2</artifactId>
		</dependency>
		<dependency>
			<groupId>io.swagger.core.v3</groupId>
			<artifactId>swagger-jaxrs2-servlet-initializer-v2</artifactId>
		</dependency>
		<dependency>
			<groupId>io.swagger.parser.v3</groupId>
			<artifactId>swagger-parser-v3</artifactId>
		</dependency>
		<dependency>
			<groupId>org.apache.commons</groupId>
			<artifactId>commons-email</artifactId>
		</dependency>
		<dependency>
			<groupId>org.apache.commons</groupId>
			<artifactId>commons-collections4</artifactId>
		</dependency>
		<dependency>
			<groupId>com.github.seancfoley</groupId>
			<artifactId>ipaddress</artifactId>
		</dependency>
		<dependency>
			<groupId>xalan</groupId>
			<artifactId>xalan</artifactId>
		</dependency>
		<dependency>
			<groupId>com.google.code.findbugs</groupId>
			<artifactId>jsr305</artifactId>
		</dependency>
		<dependency>
			<groupId>io.gsonfire</groupId>
			<artifactId>gson-fire</artifactId>
		</dependency>
		<dependency>
			<groupId>com.squareup.okhttp3</groupId>
			<artifactId>logging-interceptor</artifactId>
		</dependency>
		<dependency>
			<groupId>org.apache.oltu.oauth2</groupId>
			<artifactId>org.apache.oltu.oauth2.client</artifactId>
		</dependency>
	</dependencies>

	<build>
		<finalName>vorpal-blade-library-shared</finalName>
		<plugins>
			<!-- Step 1: Copy dependency JARs for package scanning -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-dependency-plugin</artifactId>
				<executions>
					<execution>
						<id>copy-deps-for-scan</id>
						<phase>prepare-package</phase>
						<goals><goal>copy-dependencies</goal></goals>
						<configuration>
							<outputDirectory>${project.build.directory}/dependency-jars</outputDirectory>
							<includeScope>runtime</includeScope>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!-- Step 2: Scan dependency JARs and generate weblogic.xml
			     with prefer-application-packages from actual class packages -->
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.5.0</version>
				<executions>
					<execution>
						<id>generate-weblogic-xml</id>
						<phase>prepare-package</phase>
						<goals><goal>exec</goal></goals>
						<configuration>
							<executable>bash</executable>
							<arguments>
								<argument>-c</argument>
								<argument>
JARS_DIR="${project.build.directory}/dependency-jars";
TEMPLATE="${project.basedir}/src/main/webapp/WEB-INF/weblogic.xml";
OUT_DIR="${project.build.directory}/generated-webapp/WEB-INF";
mkdir -p "$OUT_DIR";
PACKAGES=$(
  for jar in "$JARS_DIR"/*.jar; do
    jar tf "$jar" 2&gt;/dev/null;
  done | grep '\.class$' | grep -v 'META-INF/' | grep -v 'module-info' |
  sed 's|/[^/]*\.class$||' | sed 's|/|.|g' |
  awk -F. '{
    if (NF &gt;= 3) print $1"."$2"."$3
    else if (NF == 2) print $1"."$2
    else if (NF &gt;= 1) print $1
  }' | sort -u
);
while IFS= read -r line; do
  if echo "$line" | grep -q 'AUTO-GENERATED'; then
    echo "$PACKAGES" | while read -r pkg; do
      if [ -n "$pkg" ]; then
        echo "            &lt;wls:package-name&gt;$pkg.*&lt;/wls:package-name&gt;"
      fi
    done
  else
    echo "$line"
  fi
done &lt; "$TEMPLATE" &gt; "$OUT_DIR/weblogic.xml";
COUNT=$(echo "$PACKAGES" | grep -c . || true);
echo "Generated prefer-application-packages with $COUNT entries"
								</argument>
							</arguments>
						</configuration>
					</execution>
					<!-- Step 3: Strip multi-release classes above Java 11 from JARs
					     inside the WAR (post-package). Only needed for Java 11;
					     later JDKs handle multi-release JARs correctly.
					     Preserves META-INF/versions/9/ and versions/11/. -->
					<execution>
						<id>strip-multirelease</id>
						<phase>verify</phase>
						<goals><goal>exec</goal></goals>
						<configuration>
							<executable>bash</executable>
							<arguments>
								<argument>-c</argument>
								<argument>
JAVA_VER="${java.version}";
if [ "$JAVA_VER" = "11" ]; then
  WARFILE="${project.build.directory}/${project.build.finalName}.war";
  TMPDIR="${project.build.directory}/war-strip-tmp";
  mkdir -p "$TMPDIR" &amp;&amp; cd "$TMPDIR" &amp;&amp;
  jar xf "$WARFILE" WEB-INF/lib/;
  for jar in WEB-INF/lib/*.jar; do
    for ver in $(jar tf "$jar" 2>/dev/null | grep 'META-INF/versions/' | sed 's|META-INF/versions/||' | cut -d/ -f1 | sort -un); do
      if [ "$ver" -gt 11 ]; then
        zip -qd "$jar" "META-INF/versions/$ver/*" 2>/dev/null || true
      fi
    done
  done;
  jar uf "$WARFILE" WEB-INF/lib/;
  rm -rf "$TMPDIR";
  echo "Stripped multi-release classes above Java 11 from shared WAR JARs"
else
  echo "Skipping multi-release stripping (java.version=$JAVA_VER, only needed for 11)"
fi
								</argument>
							</arguments>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!-- Step 4: Package as WAR -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-war-plugin</artifactId>
				<configuration>
					<!-- Override skinny WAR setting — this WAR must include all JARs -->
					<packagingExcludes>none</packagingExcludes>
					<!-- Exclude template weblogic.xml; use generated version -->
					<warSourceExcludes>WEB-INF/weblogic.xml</warSourceExcludes>
					<webResources>
						<resource>
							<directory>${project.build.directory}/generated-webapp</directory>
						</resource>
					</webResources>
					<archive>
						<manifestEntries>
							<Specification-Title>vorpal-blade-library-shared</Specification-Title>
							<Specification-Version>2.0</Specification-Version>
							<Implementation-Title>vorpal-blade-library-shared.war</Implementation-Title>
							<Implementation-Version>${revision}</Implementation-Version>
							<Extension-Name>vorpal-blade</Extension-Name>
							<Copyright>${blade.copyright}</Copyright>
							<License>${blade.license}</License>
							<Built-By>${user.name}</Built-By>
							<Implementation-Build-Date>${maven.build.timestamp}</Implementation-Build-Date>
						</manifestEntries>
					</archive>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
