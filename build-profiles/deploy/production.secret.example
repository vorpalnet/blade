# BLADE deployment secrets — production
#
# 1. Copy this file to production.secret (drop the .example suffix)
# 2. Fill in the actual password
# 3. chmod 600 production.secret
#
# Files named *.secret are gitignored; *.secret.example templates are committed.
# deploy.sh refuses to run if production.secret is not gitignored (git check-ignore guard).

wls.password=REPLACE_ME
