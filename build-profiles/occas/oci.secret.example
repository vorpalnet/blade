# OCCAS install secrets — OCI.
# 1. cp oci.secret.example oci.secret   2. fill in   3. chmod 600 oci.secret
# Files named *.secret are gitignored; *.secret.example templates are committed.

# The 'weblogic' admin password set into the new domain by the configure step.
admin.password=REPLACE_ME

# Oracle SSO (oracle.com account) password for the eDelivery download step.
# Username goes in the conf (sso.username) or $BLADE_SSO_USERNAME. Optional —
# the download step prompts when absent.
# sso.password=REPLACE_ME
