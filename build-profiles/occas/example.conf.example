# OCCAS silent install + dynamic-cluster domain config — EXAMPLE TEMPLATE.
# Copy to <env>.conf and edit, or better: run './install-occas.sh <env> init'
# and let the interview write it for you. Real env confs are gitignored —
# they carry your site's hostnames/IPs and must never be committed.
# Full walkthrough: build-profiles/occas/README.md
# Admin password lives in <env>.secret (gitignored), not here.

# ============================================================================
# Step -1 — prep (runs AUTOMATICALLY via sudo when first needed)
# ============================================================================
# Creates install.user + inventory.group and the oracle.home / installer /
# inventory / java directories, owned by YOU (group-shared with the oracle
# user via setgid). Manual form:  sudo ./install-occas.sh <env> prep
# install.user=oracle

# ============================================================================
# Step 0 — download the media from Oracle eDelivery
# ============================================================================
# './install-occas.sh <env> download' fetches the installer media headlessly
# (curl); 'install' auto-runs it when installer.jar is missing. One-time
# browser step per release (license click + wget.sh + access token) — the
# script walks you through it; details in the README.
# download.urls.file=build-profiles/occas/<env>.urls
# download.dir=<dirname of installer.jar; falls back to ~/occas-media>

# --- Oracle JDKs (official tarballs from download.oracle.com — no login) ---
# java.runtime: what OCCAS runs on — keep to Oracle's certification matrix
# for this OCCAS release (8.3 → JDK 21). java.javadoc: for blade javadoc
# builds (Markdown /// needs JDK 23+). Blank/absent = skip that one.
java.runtime=21
java.javadoc=25
# Shared location (created by prep) — NOT under a user home: the servers run
# as the oracle user, which can't traverse /home/<you> (mode 700).
java.dir=/opt/oracle/java

# ============================================================================
# Step 1 — silent product install
# ============================================================================
# Where OCCAS gets installed (becomes $MW_HOME / ORACLE_HOME).
oracle.home=/opt/oracle/occas/8.3
# The OCCAS installer jar — always named occas_generic.jar. Keep it under a
# prep-created shared dir, NOT under a user home (mode-700 homes don't share).
# Override per-box without editing this: BLADE_OCCAS_INSTALLER=/path/occas_generic.jar
installer.jar=/opt/oracle/install/occas-8.3/occas_generic.jar
# Oracle central inventory (created on first install on this host).
inventory.loc=/opt/oracle/oraInventory
inventory.group=oinstall
install.type=Complete with Examples

# ============================================================================
# Step 2 — dynamic-cluster domain (occas-replicated-dynamiccluster.py)
# ============================================================================
# Domain name. NOTE: configure writes with OverwriteDomain=true — pointing this
# at an EXISTING domain dir CLOBBERS it. Back up first.
domain.name=replicated
# 'prod' or 'dev'
server.start.mode=prod
admin.username=weblogic

# --- Dynamic cluster shape (BEA_ENGINE_TIER_CLUST) ---
# Generated servers are named <prefix>1, <prefix>2, … and auto-assigned to the
# machines whose names match machine.match.expression.
server.name.prefix=engine
machine.match.expression=engine*
# MaximumDynamicServerCount — how many engine servers exist now.
dynamic.server.count=2
# MaxDynamicClusterSize — the growth ceiling.
max.dynamic.cluster.size=8

# --- Physical machines + their Node Managers ---
# CSV per machine: name:nmListenAddress:nmListenPort:nmType  (nmType = ssl|plain)
# The AdminServer host is registered too (so it's NM-managed) but its name does
# NOT match machine.match.expression, so no engine servers land on it.
# To ADD A NODE: add a machine.N line here, bump dynamic.server.count, re-run
#   ./install-occas.sh <env> configure   (see the header of install-occas.sh).
machine.1=admin:10.0.0.11:5556:ssl
machine.2=engine1:10.0.0.12:5556:ssl
machine.3=engine2:10.0.0.13:5556:ssl

# --- Optional static test engine on the AdminServer box ---
# A fixed engine-tier member for testing / BLADE config-file generation, on the
# admin machine (which doesn't match machine.match.expression, so no dynamic
# server lands there). Leave blank to skip.
# Format: name:machine:listenPort:sipPort:sipsPort
static.server=engine0:admin:8001:5060:5061

# --- TLS (steps: certs.sh + 'install-occas.sh <env> secure') ---
# 1. ./certs.sh <env> generate      (test PKI)  — or 'import' for customer-issued
# 2. ./install-occas.sh <env> secure  (domain stopped) — wires the keystores +
#    SSL ports into AdminServer, the engine template, and the static engine.
# Defaults shown; uncomment to override. store.password lives in <env>.secret.
# certs.dir=~/.blade/certs/<env>
# admin.ssl.port=7002
# ssl.listen.port=8002
# identity.keystore={certs.dir}/identity.p12
# trust.keystore={certs.dir}/trust.p12
# identity.alias=server
# tls.only=false
