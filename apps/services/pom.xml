	<artifactId>vorpal-blade-services-ear</artifactId>
	<packaging>ear</packaging>
	<name>BLADE Services</name>
	<description>Single deployable bundling the production BLADE SIP services for the engine cluster (BEA_ENGINE_TIER_CLUST). Each WAR is self-contained (carries the framework and references the blade-shared shared library via its own weblogic.xml); this EAR is a packaging convenience and bundles no libraries. Each service is contributed by its ear-name profile, activated by skip-name, so a trimmed build profile yields a matching EAR. proxy-registrar is intentionally excluded (wide open / test-only) and ships only in blade-test.ear; acl was moved to proto and is not shipped.</description>

	<build>
		<finalName>blade-services</finalName>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-ear-plugin</artifactId>
				<configuration>
					<version>8</version>
					<generateApplicationXml>true</generateApplicationXml>
					<displayName>BLADE Services</displayName>
				</configuration>
			</plugin>
		</plugins>
	</build>

