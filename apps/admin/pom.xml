	<artifactId>vorpal-blade-admin-ear</artifactId>
	<packaging>ear</packaging>
	<name>BLADE Admin EAR</name>
	<description>Single deployable that bundles every BLADE admin webapp, so the
		whole admin tier deploys to AdminServer in one step. Each WAR is
		self-contained exactly as it deploys on its own — it carries the
		framework jar and references the `blade-shared` shared library via its
		own weblogic.xml (the proven per-WAR model). This EAR is purely a
		packaging convenience over those WARs; it bundles no libraries itself.
		An individual admin app can still be redeployed on its own for testing.

		Each admin app is contributed by its own ear-&lt;name&gt; profile, activated by
		!skip.&lt;name&gt; — the same flags build.sh derives from the active
		build-profiles/*.conf. So a trimmed profile that builds only a subset of
		admin apps produces an EAR containing exactly that subset, with no
		dangling references to WARs that aren't in the reactor. The javadoc WAR
		is contributed by the `javadocs` profile id — the one build.sh activates
		when generating docs — so the EAR carries javadoc.war exactly when the
		docs are built, and assembles without it otherwise (--no-javadoc or an
		old build JDK no longer skips the whole EAR).

		admin/watcher was retired (moved to retired/watcher) and is no longer
		built or bundled; the Configurator's auto-publish covers that need.</description>

	<dependencies>
		<!-- Admin WAR modules are contributed via the ear-* profiles below.
		     No JARs in this EAR — framework is in each WAR, 3rd-party libs come
		     from the blade-shared shared library at runtime. -->
	</dependencies>

	<build>
		<finalName>blade-admin</finalName>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-ear-plugin</artifactId>
				<configuration>
					<!-- Jakarta EE 8 (OCCAS / WebLogic 14.1.1). -->
					<version>8</version>
					<generateApplicationXml>true</generateApplicationXml>
					<displayName>BLADE Admin</displayName>
					<!-- Context roots are stated explicitly (per webModule in the
					     profiles below) so they exactly match each WAR's weblogic.xml;
					     application.xml wins over weblogic.xml in an EAR. Never change
					     them — they are fixed deployment identifiers. -->
				</configuration>
			</plugin>
		</plugins>
	</build>

	<profiles>
		<!-- One profile per admin WAR. Active by default; build.sh excludes an
		     app with -Dskip.<name> when it's absent from the active
		     build-profiles/*.conf. Each profile contributes BOTH the war
		     dependency AND its webModule (combine.children="append"), so the two
		     never drift and a skipped app drops cleanly out of the EAR. The
		     javadoc WAR rides the `javadocs` profile id instead (see above). -->
		<profile>
			<id>ear-portal</id>
			<activation><property><name>!skip.portal</name></property></activation>
			<dependencies>
				<dependency>
					<groupId>org.vorpal.blade</groupId>
					<artifactId>vorpal-blade-admin-portal</artifactId>
					<version>${project.version}</version>
					<type>war</type>
					<exclusions><exclusion><groupId>*</groupId><artifactId>*</artifactId></exclusion></exclusions>
				</dependency>
			</dependencies>
			<build><plugins><plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-ear-plugin</artifactId>
				<configuration>
					<modules combine.children="append">
						<webModule>
							<groupId>org.vorpal.blade</groupId>
							<artifactId>vorpal-blade-admin-portal</artifactId>
							<contextRoot>blade/portal</contextRoot>
							<bundleFileName>blade-portal.war</bundleFileName>
						</webModule>
					</modules>
				</configuration>
			</plugin></plugins></build>
		</profile>
