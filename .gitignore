# OS
.DS_Store
Thumbs.db

# Logs
*.log
*.log.lck

# Deployment secrets — NEVER commit passwords or connection secrets.
# Templates named *.secret.example ARE committed (negation below).
build-profiles/deploy/*.secret
!build-profiles/deploy/*.secret.example

# BLADE install profiles (host facts, IPs, secrets) — never commit.
/.conf/

# Node Manager password drop for misc/start-admin-nm.sh — never commit.
# (The systemd boot service uses <domain>/.blade-nm.env, which lives outside the
# repo under MW_HOME; this covers the in-repo .nmsecret convenience file.)
misc/.nmsecret
