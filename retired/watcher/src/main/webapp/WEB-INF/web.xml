<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	version="4.0">
	<display-name>watcher</display-name>
	<!--
		Intentionally minimal. watcher is a headless background app:
		no servlets, no JSPs, no static content, no security constraints,
		no login config. The only thing that runs is a @WebListener that
		starts a WatchService thread on context init and stops it on
		context destroy. The thread auto-publishes *.json config changes
		via JMX. There is nothing to log into.
	-->
</web-app>
