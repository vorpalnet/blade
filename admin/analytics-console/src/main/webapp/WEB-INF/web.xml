<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_AnalyticsConsole" version="4.0">

	<!-- display-name → JMX MBean key (vorpal.blade:Name=analytics-console) and
	     the on-disk config file name. Deliberately NOT "analytics": that would
	     collide with the analytics CLUSTER SERVICE, which also registers
	     Name=analytics. Context-root stays blade/analytics (see weblogic.xml). -->
	<display-name>analytics-console</display-name>

	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
	</welcome-file-list>

</web-app>
