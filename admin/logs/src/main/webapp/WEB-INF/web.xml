<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_Logs" version="4.0">

	<display-name>blade-logs</display-name>

	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
	</welcome-file-list>

	<!-- Registers the per-JVM VorpalLogReader MBean. Listener class is a thin
	     shim in this WAR's own classes so WLS's deployment-activation pass
	     can resolve it; the shim then delegates to the framework registrar
	     once the shared-library classloader is merged in.
	     Idempotent — safe to declare in any number of WARs in the same JVM. -->
	<listener>
		<listener-class>org.vorpal.blade.applications.logs.LogReaderListener</listener-class>
	</listener>

</web-app>
