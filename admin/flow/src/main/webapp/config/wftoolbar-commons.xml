<mxDefaultToolbar>
	<!-- Open / Load: one button for every way a config comes IN — local file,
	     paste, the live fsmar3, or the sample. -->
	<add as="importFsmar" action="importFsmar" icon="svg/folder-open.svg"/>
	<!-- Save / Export: one button for every way a config goes OUT — download,
	     copy, or publish to the live fsmar3 (with validation). -->
	<add as="exportFsmar" action="exportFsmar" icon="svg/save.svg"/>
	<add as="exportImage" action="exportImage" icon="svg/image.svg"/>
	<add as="printReport" action="printReport" icon="svg/print.svg"/>

	<br/><hr/>
	<add as="simulateFsmar" action="simulateFsmar" icon="svg/simulate.svg"/>
	<add as="jsonView" action="jsonView" icon="svg/braces.svg"/>

	<br/><hr/>
	<add as="select" mode="select" icon="svg/mouse-pointer.svg"/>
	<add as="pan" mode="pan" icon="svg/hand-paper.svg"/>
	<add as="connect" mode="connect" icon="svg/connect.svg"/>
	<add as="group" action="group" icon="svg/object-group.svg"/>
	<add as="ungroup" action="ungroup" icon="svg/object-ungroup.svg"/>
	<add as="autoLayout" action="autoLayout" icon="svg/auto-layout.svg"/>

	<br/><hr/>
	<add as="Gateway" template="gateway" style="gateway" icon="svg/cloud-download.svg"/>
	<add as="Egress" template="egress" style="egress" icon="svg/cloud-upload.svg"/>
	<add as="State" template="state" style="state" icon="svg/rectangle-landscape.svg"/>

	<br/><hr/>
	<add as="cut" action="cut" icon="svg/cut.svg"/>
	<add as="copy" action="copy" icon="svg/copy.svg"/>
	<add as="paste" action="paste" icon="svg/paste.svg"/>
	<add as="delete" action="delete" icon="svg/backspace.svg"/>
	<add as="undo" action="undo" icon="svg/undo.svg"/>
	<add as="redo" action="redo" icon="svg/redo.svg"/>

	<br/><hr/>
	<add as="fit" action="fit" icon="svg/search.svg"/>
	<add as="zoomIn" action="zoomIn" icon="svg/search-plus.svg"/>
	<add as="zoomOut" action="zoomOut" icon="svg/search-minus.svg"/>

	<br/><hr/>
	<add as="tasks" action="toggleTasks" icon="svg/clipboard-check.svg"/>
	<add as="help" action="toggleHelp" icon="svg/question-circle.svg"/>
	<add as="properties" action="showProperties" icon="svg/cog.svg"/>
</mxDefaultToolbar>
