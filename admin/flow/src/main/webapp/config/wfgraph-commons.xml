<mxGraph alternateEdgeStyle="verticalEdge" dropEnabled="1">
	<add as="getTooltipForCell"><![CDATA[
		function(cell)
		{
			var tag = cell.value ? cell.value.tagName : '';
			var label = cell.getAttribute('label') || '';
			var info = '';

			if (tag === 'Transition') {
				var txId = cell.getAttribute('txId') || '';
				var subscriber = cell.getAttribute('subscriber') || '';
				if (txId) info += '<br>id: ' + txId;
				if (subscriber) info += '<br>subscriber: ' + subscriber;
			}

			return '<b>' + tag + ': ' + label + '</b>' + info +
					'<br>Edges: ' + cell.getEdgeCount() +
					'<br>Children: ' + cell.getChildCount();
		}
	]]></add>
	<add as="convertValueToString">
		function(cell)
		{
			return cell.getAttribute('label');
		}
	</add>
	<mxGraphModel as="model">
		<add as="valueForCellChanged"><![CDATA[
			function(cell, value)
			{
				var previous = null;

				if (isNaN(value.nodeType))
				{
					previous = cell.getAttribute('label');
					cell.setAttribute('label', value);
				}
				else
				{
					previous = cell.value;
					cell.value = value;
				}

				return previous;
			}
		]]></add>
		<root>
			<FlowModel label="FSMAR Flow" defaultApplication="" id="0"/>
			<Layer label="Default Layer">
				<mxCell parent="0"/>
			</Layer>
		</root>
	</mxGraphModel>
	<mxStylesheet as="stylesheet">
		<add as="defaultVertex">
			<add as="shape" value="label"/>
			<add as="perimeter" value="rectanglePerimeter"/>
			<add as="labelBackgroundColor" value="white"/>
			<add as="fontSize" value="11"/>
			<add as="align" value="center"/>
			<add as="verticalAlign" value="middle"/>
			<add as="strokeColor" value="black"/>
		</add>
		<add as="defaultEdge">
			<add as="shape" value="connector"/>
			<add as="labelBackgroundColor" value="white"/>
			<add as="rounded" value="1"/>
			<add as="edgeStyle" value="elbowEdgeStyle"/>
			<add as="endArrow" value="classic"/>
			<add as="strokeWidth" value="2"/>
			<add as="fontSize" value="10"/>
			<add as="align" value="center"/>
			<add as="verticalAlign" value="middle"/>
			<add as="strokeColor" value="#444444"/>
		</add>
		<add as="state">
			<add as="shape" value="rectangle"/>
			<add as="rounded" value="1"/>
			<add as="fillColor" value="#DAE8FC"/>
			<add as="strokeColor" value="#6C8EBF"/>
			<add as="strokeWidth" value="2"/>
			<add as="fontSize" value="12"/>
			<add as="fontStyle" value="1"/>
		</add>
		<add as="ingressCloud">
			<add as="shape" value="networkServer"/>
			<add as="fillColor" value="#E1D5E7"/>
			<add as="strokeColor" value="#9673A6"/>
			<add as="strokeWidth" value="2"/>
			<add as="fontSize" value="11"/>
			<add as="fontStyle" value="1"/>
			<add as="verticalLabelPosition" value="bottom"/>
			<add as="verticalAlign" value="top"/>
		</add>
		<add as="egressCloud">
			<add as="shape" value="networkServer"/>
			<add as="fillColor" value="#FFE6CC"/>
			<add as="strokeColor" value="#D79B00"/>
			<add as="strokeWidth" value="2"/>
			<add as="fontSize" value="11"/>
			<add as="fontStyle" value="1"/>
			<add as="verticalLabelPosition" value="bottom"/>
			<add as="verticalAlign" value="top"/>
		</add>
		<add as="verticalEdge">
			<add as="elbow" value="vertical"/>
		</add>
		<add as="straightEdge">
			<add as="shape" value="connector"/>
			<add as="endArrow" value="classic"/>
		</add>
		<add as="group">
			<add as="shape" value="rectangle"/>
			<add as="rounded" value="1"/>
			<add as="verticalAlign" value="top"/>
			<add as="strokeColor" value="black"/>
			<add as="dashed" value="1"/>
			<add as="opacity" value="50"/>
		</add>
	</mxStylesheet>
</mxGraph>
