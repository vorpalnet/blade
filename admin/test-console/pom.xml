<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.vorpal.blade</groupId>
		<artifactId>vorpal-blade</artifactId>
		<version>${revision}</version>
		<relativePath>../../pom.xml</relativePath>
	</parent>

	<artifactId>vorpal-blade-admin-test-console</artifactId>
	<packaging>war</packaging>
	<name>BLADE Admin Test Console</name>
	<description>Cluster-wide control surface for the BLADE test apps (test-uac, test-uas):
		start/stop load runs and watch live per-scenario metrics across every node, over
		federated JMX from the AdminServer.</description>

	<dependencies>
		<dependency>
			<groupId>org.vorpal.blade</groupId>
			<artifactId>vorpal-blade-library-framework</artifactId>
		</dependency>
	</dependencies>

	<build>
		<finalName>test-console</finalName>
		<!-- Inherits the parent pom's maven-war-plugin packagingExcludes regex,
		     which bundles ONLY vorpal-blade-library-framework.jar -->
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-war-plugin</artifactId>
				<configuration>
					<!-- The login page is the portal master, injected at build time:
					     one source file, no per-app copies to drift. Edit
					     admin/portal/src/main/webapp/login.jsp, never add a per-app
					     login page. See SECURITY.md. -->
					<webResources>
						<resource>
							<directory>${project.basedir}/../portal/src/main/webapp</directory>
							<includes>
								<include>login.jsp</include>
							</includes>
						</resource>
					</webResources>
				</configuration>
			</plugin>
		</plugins>
	</build>


</project>
