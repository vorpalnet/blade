	<build>
		<!-- Bundle .java sources alongside .class files in every module's
		     output (target/classes/, then WEB-INF/classes/ in WARs). Lets
		     us read source straight out of a deployed artifact when
		     troubleshooting on a customer cluster. The framework library
		     opts out of this and emits a separate -sources.jar instead;
		     see libs/framework/pom.xml. -->
		<resources>
			<resource>
				<directory>src/main/resources</directory>
			</resource>
			<resource>
				<directory>${project.build.sourceDirectory}</directory>
				<includes>
					<include>**/*.java</include>
				</includes>
			</resource>
		</resources>
		<pluginManagement>
			<plugins>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-compiler-plugin</artifactId>
					<version>${maven-compiler-plugin.version}</version>
					<configuration>
						<release>${blade.java.version}</release>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-war-plugin</artifactId>
					<version>${maven-war-plugin.version}</version>
					<configuration>
						<!-- WAR filename follows finalName so it matches the context-root.
						     Each child WAR pom sets finalName to its <wls:context-root>
						     value (e.g. configurator → configurator.war, hold → hold.war).
						     Customers prefer short context-matching names over the long
						     artifactId-based names (e.g. vorpal-blade-admin-configurator.war).
						     warName defaults to ${project.build.finalName}, so we don't set
						     it explicitly — it's read-only in war-plugin 3.4.0 and setting it
						     just emits a "must not be used in configuration" warning per WAR. -->
						<failOnMissingWebXml>false</failOnMissingWebXml>
						<!-- Include only the framework JAR; 3rd-party JARs come from the shared library -->
						<packagingExcludes>%regex[WEB-INF/lib/(?!vorpal-blade-library-framework).*\.jar]</packagingExcludes>
						<archive>
							<manifestEntries>
								<Implementation-Build-Date>${maven.build.timestamp}</Implementation-Build-Date>
								<WebLogic-Application-Version>${revision}-${build.number}</WebLogic-Application-Version>
								<Copyright>${blade.copyright}</Copyright>
								<License>${blade.license}</License>
								<Built-By>${user.name}</Built-By>
							</manifestEntries>
						</archive>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-jar-plugin</artifactId>
					<version>${maven-jar-plugin.version}</version>
					<configuration>
						<!-- Always rebuild the jar, even when contents look unchanged.
						     The fsmar fat-jar modules run shade:shade, which OVERWRITES
						     target/<finalName>.jar with the uber-jar. On an incremental
						     build (no clean), the default forceCreation=false skips
						     jar:jar, so shade re-shades last build's fat jar against the
						     same deps - producing thousands of bogus "overlapping
						     classes" warnings and risking stale classes from removed
						     deps surviving. See the maven-shade-plugin FAQ. -->
						<forceCreation>true</forceCreation>
						<archive>
							<manifestEntries>
								<Implementation-Build-Date>${maven.build.timestamp}</Implementation-Build-Date>
								<WebLogic-Application-Version>${revision}-${build.number}</WebLogic-Application-Version>
								<Copyright>${blade.copyright}</Copyright>
								<License>${blade.license}</License>
								<Built-By>${user.name}</Built-By>
							</manifestEntries>
						</archive>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-ear-plugin</artifactId>
					<version>${maven-ear-plugin.version}</version>
					<configuration>
						<archive>
							<manifestEntries>
								<Implementation-Build-Date>${maven.build.timestamp}</Implementation-Build-Date>
								<WebLogic-Application-Version>${revision}-${build.number}</WebLogic-Application-Version>
								<Copyright>${blade.copyright}</Copyright>
								<License>${blade.license}</License>
								<Built-By>${user.name}</Built-By>
							</manifestEntries>
						</archive>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-install-plugin</artifactId>
					<version>${maven-install-plugin.version}</version>
				</plugin>
			</plugins>
		</pluginManagement>
		<plugins>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>flatten-maven-plugin</artifactId>
				<version>1.6.0</version>
				<configuration>
					<updatePomFile>true</updatePomFile>
					<flattenMode>resolveCiFriendliesOnly</flattenMode>
				</configuration>
				<executions>
					<execution>
						<id>flatten</id>
						<phase>process-resources</phase>
						<goals><goal>flatten</goal></goals>
					</execution>
					<execution>
						<id>flatten-clean</id>
						<phase>clean</phase>
						<goals><goal>clean</goal></goals>
					</execution>
				</executions>
			</plugin>
			<!-- Install the parent POM and framework JAR to .m2; skip all others.
		     The parent POM must be installed because the framework JAR references it,
		     and downstream modules (fsmar, fsmar3, shared) need to resolve it. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-install-plugin</artifactId>
				<configuration>
					<skip>${blade.skip.install}</skip>
				</configuration>
				<executions>
					<execution>
						<id>install-parent-pom</id>
						<phase>install</phase>
						<goals><goal>install</goal></goals>
						<inherited>false</inherited>
						<configuration>
							<skip>false</skip>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!-- Dist copy moved to services/pom.xml (EAR, built last) -->
			<!-- Sync exploded WAR directory with the packaged WAR.
			     The WAR plugin's packagingExcludes strips 3rd-party JARs from
			     the .war archive but leaves them in the exploded directory.
			     This re-syncs the exploded lib/ from the WAR so deploying
			     the exploded directory works the same as deploying the WAR.

			     Both the WAR filename and the exploded directory derive from
			     finalName (war-plugin's warName defaults to it), so they
			     share a basename. -->
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.5.0</version>
				<executions>
					<execution>
						<id>sync-exploded-lib</id>
						<phase>package</phase>
						<goals><goal>exec</goal></goals>
						<configuration>
							<executable>bash</executable>
							<arguments>
								<argument>-c</argument>
								<argument>
WARFILE="${project.build.directory}/${project.build.finalName}.war";
EXPLODED="${project.build.directory}/${project.build.finalName}";
if [ -f "$WARFILE" ] &amp;&amp; [ -d "$EXPLODED/WEB-INF/lib" ]; then
  rm -rf "$EXPLODED/WEB-INF/lib";
  cd "$EXPLODED" &amp;&amp; jar xf "$WARFILE" WEB-INF/lib/ 2>/dev/null || true;
fi
								</argument>
							</arguments>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

	<profiles>
		<!-- Library module profiles. Active by default; exclude with -Dskip.<name>.
		     Build-profiles/*.conf files select which libraries to include.
		     Note: most service/admin/test modules depend on `framework` and
		     `shared` at compile time. If you skip them here, they must already
		     be installed in your local Maven repo from a prior build. -->
		<profile>
			<id>framework</id>
			<activation><property><name>!skip.framework</name></property></activation>
			<modules><module>libs/framework</module></modules>
		</profile>
		<profile>
			<id>shared</id>
			<activation><property><name>!skip.shared</name></property></activation>
			<modules><module>libs/shared</module></modules>
		</profile>
		<profile>
			<id>fsmar</id>
			<activation><property><name>!skip.fsmar</name></property></activation>
			<modules><module>libs/fsmar</module></modules>
		</profile>
		<profile>
			<id>fsmar3</id>
			<activation><property><name>!skip.fsmar3</name></property></activation>
			<modules><module>libs/fsmar3</module></modules>
		</profile>

		<!-- Service/test module profiles. Active by default; exclude with -Dskip.<name> -->
		<profile>
			<id>acl</id>
			<activation><property><name>!skip.acl</name></property></activation>
			<modules><module>services/acl</module></modules>
		</profile>
		<profile>
			<id>analytics</id>
			<activation><property><name>!skip.analytics</name></property></activation>
