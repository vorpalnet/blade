		<!-- The admin EAR (admin/ear, module name "ear"): assembles the admin
		     WARs into one deployable (blade-admin.ear). Active by default;
		     exclude with -Dskip.ear. Each admin app is contributed by an
		     ear-<name> profile inside admin/ear/pom.xml (activated by
		     !skip.<name>), so the EAR shrinks to match a trimmed build profile.
		     The javadoc WAR rides the `javadocs` profile id — the EAR carries
		     javadoc.war exactly when docs are generated and assembles without
		     it otherwise. -->
		<profile>
			<id>ear</id>
			<activation><property><name>!skip.ear</name></property></activation>
			<modules><module>admin/ear</module></modules>
		</profile>

		<!-- The cluster EAR (services/cluster, module name "cluster"): assembles
		     every engine-tier service WAR into one deployable (blade-cluster.ear),
		     the mirror of admin/ear. Active by default; exclude with -Dskip.cluster.
		     Each service is contributed by an ear-<name> profile inside
		     services/cluster/pom.xml, so the EAR shrinks to match a trimmed
		     build profile (e.g. minimal). -->
		<profile>
			<id>cluster</id>
			<activation><property><name>!skip.cluster</name></property></activation>
			<modules><module>services/cluster</module></modules>
		</profile>

		<profile>
			<id>javadocs</id>
			<modules>
				<module>admin/javadoc</module>
			</modules>
			<build>
				<plugins>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-javadoc-plugin</artifactId>
						<version>${maven-javadoc-plugin.version}</version>
						<executions>
							<execution>
								<id>generate-javadocs</id>
								<phase>package</phase>
								<goals>
									<goal>javadoc</goal>
								</goals>
							</execution>
						</executions>
						<configuration>
							<source>${blade.java.version}</source>
							<doclet>nl.talsmasoftware.umldoclet.UMLDoclet</doclet>
							<docletArtifact>
								<groupId>nl.talsmasoftware</groupId>
								<artifactId>umldoclet</artifactId>
								<version>${umldoclet.version}</version>
							</docletArtifact>
							<additionalOptions>
								<additionalOption>-failOnCyclicPackageDependencies false</additionalOption>
								<additionalOption>--add-stylesheet ${maven.multiModuleProjectDirectory}/admin/javadoc/src/main/resources/vorpal-theme.css</additionalOption>
								<additionalOption>--add-script ${maven.multiModuleProjectDirectory}/admin/javadoc/src/main/resources/overview-toc.js</additionalOption>
								<additionalOption>--allow-script-in-comments</additionalOption>
							</additionalOptions>
							<excludePackageNames>gov.nist.*:javax.sdp.*</excludePackageNames>
							<show>public</show>
							<doclint>none</doclint>
							<failOnError>false</failOnError>
							<links>
								<link>https://docs.oracle.com/en/java/javase/11/docs/api</link>
								<link>https://javaee.github.io/javaee-spec/javadocs/</link>
								<link>https://jakarta.ee/specifications/platform/8/apidocs/</link>
								<link>https://vorpal.net/javadocs/jsr359/</link>
							</links>
