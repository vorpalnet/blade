	<build>
		<pluginManagement>
			<plugins>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-compiler-plugin</artifactId>
					<version>${maven-compiler-plugin.version}</version>
					<configuration>
						<release>${blade.java.version}</release>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-war-plugin</artifactId>
					<version>${maven-war-plugin.version}</version>
					<configuration>
						<warName>${project.artifactId}</warName>
						<failOnMissingWebXml>false</failOnMissingWebXml>
						<!-- Include only the framework JAR; 3rd-party JARs come from the shared library -->
						<packagingExcludes>%regex[WEB-INF/lib/(?!vorpal-blade-library-framework).*\.jar]</packagingExcludes>
						<archive>
							<manifestEntries>
								<Implementation-Build-Date>${maven.build.timestamp}</Implementation-Build-Date>
								<WebLogic-Application-Version>${revision}-${build.number}</WebLogic-Application-Version>
								<Copyright>${blade.copyright}</Copyright>
								<License>${blade.license}</License>
								<Built-By>${user.name}</Built-By>
							</manifestEntries>
						</archive>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-jar-plugin</artifactId>
					<version>${maven-jar-plugin.version}</version>
					<configuration>
						<archive>
							<manifestEntries>
								<Implementation-Build-Date>${maven.build.timestamp}</Implementation-Build-Date>
								<WebLogic-Application-Version>${revision}-${build.number}</WebLogic-Application-Version>
								<Copyright>${blade.copyright}</Copyright>
								<License>${blade.license}</License>
								<Built-By>${user.name}</Built-By>
							</manifestEntries>
						</archive>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-ear-plugin</artifactId>
					<version>${maven-ear-plugin.version}</version>
					<configuration>
						<archive>
							<manifestEntries>
								<Implementation-Build-Date>${maven.build.timestamp}</Implementation-Build-Date>
								<WebLogic-Application-Version>${revision}-${build.number}</WebLogic-Application-Version>
								<Copyright>${blade.copyright}</Copyright>
								<License>${blade.license}</License>
								<Built-By>${user.name}</Built-By>
							</manifestEntries>
						</archive>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-install-plugin</artifactId>
					<version>${maven-install-plugin.version}</version>
				</plugin>
			</plugins>
		</pluginManagement>
		<plugins>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>flatten-maven-plugin</artifactId>
				<version>1.6.0</version>
				<configuration>
					<updatePomFile>true</updatePomFile>
					<flattenMode>resolveCiFriendliesOnly</flattenMode>
				</configuration>
				<executions>
					<execution>
						<id>flatten</id>
						<phase>process-resources</phase>
						<goals><goal>flatten</goal></goals>
					</execution>
					<execution>
						<id>flatten-clean</id>
						<phase>clean</phase>
						<goals><goal>clean</goal></goals>
					</execution>
				</executions>
			</plugin>
			<!-- Install the parent POM and framework JAR to .m2; skip all others.
		     The parent POM must be installed because the framework JAR references it,
		     and downstream modules (fsmar, fsmar3, shared) need to resolve it. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-install-plugin</artifactId>
				<configuration>
					<skip>${blade.skip.install}</skip>
				</configuration>
				<executions>
					<execution>
						<id>install-parent-pom</id>
						<phase>install</phase>
						<goals><goal>install</goal></goals>
						<inherited>false</inherited>
						<configuration>
							<skip>false</skip>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!-- Dist copy moved to services/pom.xml (EAR, built last) -->
			<!-- Sync exploded WAR directory with the packaged WAR.
			     The WAR plugin's packagingExcludes strips 3rd-party JARs from
			     the .war archive but leaves them in the exploded directory.
			     This re-syncs the exploded lib/ from the WAR so deploying
			     the exploded directory works the same as deploying the WAR.

			     The packaged WAR's filename follows the war-plugin's warName
			     setting (above: ${project.artifactId}.war), while the exploded
			     directory uses Maven's default finalName. Services set a short
			     finalName (e.g. proxy-registrar) so the two differ — this script
			     addresses both explicitly. -->
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.5.0</version>
				<executions>
					<execution>
						<id>sync-exploded-lib</id>
						<phase>package</phase>
						<goals><goal>exec</goal></goals>
						<configuration>
							<executable>bash</executable>
							<arguments>
								<argument>-c</argument>
								<argument>
WARFILE="${project.build.directory}/${project.artifactId}.war";
EXPLODED="${project.build.directory}/${project.build.finalName}";
if [ -f "$WARFILE" ] &amp;&amp; [ -d "$EXPLODED/WEB-INF/lib" ]; then
  rm -rf "$EXPLODED/WEB-INF/lib";
  cd "$EXPLODED" &amp;&amp; jar xf "$WARFILE" WEB-INF/lib/ 2>/dev/null || true;
fi
								</argument>
							</arguments>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

