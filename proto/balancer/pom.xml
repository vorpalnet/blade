<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.vorpal.blade</groupId>
		<artifactId>vorpal-blade</artifactId>
		<version>${revision}</version>
		<relativePath>../../pom.xml</relativePath>
	</parent>

	<artifactId>vorpal-blade-admin-balancer</artifactId>
	<packaging>war</packaging>
	<name>BLADE Admin Balancer Health</name>
	<description>Endpoint-health dashboard for the Proxy Balancer service: shows every
		engine node's independent view of every plan/tier/endpoint — up, down, or in
		Retry-After backoff — read live over federated JMX.</description>

	<dependencies>
		<dependency>
			<groupId>org.vorpal.blade</groupId>
			<artifactId>vorpal-blade-library-framework</artifactId>
		</dependency>
	</dependencies>

	<build>
		<finalName>blade-balancer</finalName>
		<!-- Inherits the parent pom's maven-war-plugin packagingExcludes regex,
		     which bundles ONLY vorpal-blade-library-framework.jar -->
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-war-plugin</artifactId>
				<configuration>
					<webResources>
						<!-- Portal master login page, injected at build time. -->
						<resource>
							<directory>${project.basedir}/../../admin/portal/src/main/webapp</directory>
							<includes>
								<include>login.jsp</include>
							</includes>
						</resource>
					</webResources>
				</configuration>
			</plugin>
		</plugins>
	</build>

</project>
