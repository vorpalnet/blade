<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_TestConsole" version="4.0">

	<display-name>test-console</display-name>

	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
	</welcome-file-list>

	<!-- Registers the SettingsManager so the app's name/tagline appear on the
	     Admin Portal launcher deck. -->
	<listener>
		<listener-class>org.vorpal.blade.applications.testconsole.TestConsoleStartup</listener-class>
	</listener>

	<!-- login.jsp must be reachable WITHOUT auth, or the FORM login forward
	     loops. Its CSS/logo/favicon come from /blade/portal/brand/* (served by
	     the portal WAR, open there) — so nothing else needs to be public here. -->
	<security-constraint>
		<web-resource-collection>
			<web-resource-name>public-login</web-resource-name>
			<url-pattern>/login.jsp</url-pattern>
		</web-resource-collection>
	</security-constraint>

	<security-constraint>
		<web-resource-collection>
			<web-resource-name>app</web-resource-name>
			<url-pattern>/*</url-pattern>
		</web-resource-collection>
		<auth-constraint>
			<role-name>Admin</role-name>
			<role-name>Operator</role-name>
			<role-name>Deployer</role-name>
			<role-name>Monitor</role-name>
		</auth-constraint>
	</security-constraint>

	<login-config>
		<auth-method>CLIENT-CERT,FORM</auth-method>
		<realm-name>default</realm-name>
		<form-login-config>
			<form-login-page>/login.jsp</form-login-page>
			<form-error-page>/login.jsp</form-error-page>
		</form-login-config>
	</login-config>

	<security-role>
		<role-name>Admin</role-name>
	</security-role>
	<security-role>
		<role-name>Operator</role-name>
	</security-role>
	<security-role>
		<role-name>Deployer</role-name>
	</security-role>
	<security-role>
		<role-name>Monitor</role-name>
	</security-role>

</web-app>
